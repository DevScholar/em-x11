{
  "name": "@devscholar/em-x11",
  "version": "0.0.1",
  "description": "A WASM/HTML5 implementation of the X11/Xlib C API. Programs link against em-x11 and draw directly to an HTML canvas; there is no real X server.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0",
  "files": [
    "dist",
    "native/include",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm run build:native && pnpm run build:web",
    "build:native": "emcmake cmake -S . -B build -DCMAKE_BUILD_TYPE=Release && cmake --build build -j",
    "build:native:debug": "emcmake cmake -S . -B build -DCMAKE_BUILD_TYPE=Debug && cmake --build build -j",
    "build:web": "vite build",
    "dev": "vite",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "clean": "rimraf build dist",
    "clean:all": "rimraf build dist node_modules"
  },
  "devDependencies": {
    "@types/emscripten": "^1.39.10",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.4.0",
    "vite": "^5.2.0"
  },
  "keywords": [
    "x11",
    "xlib",
    "wasm",
    "webassembly",
    "emscripten",
    "canvas",
    "tk",
    "tkinter"
  ]
}
